# Backend: Ollama (local dev) or vLLM (eval)
# Ollama:  http://localhost:11434/v1
# vLLM:    http://localhost:8000/v1
TARGET_BASE_URL=http://localhost:11434/v1
ATTACKER_BASE_URL=http://localhost:11434/v1

# Model IDs (Ollama tag or HF model ID)
TARGET_MODEL=gemma4:26b
ATTACKER_MODEL=gemma4:e4b
JUDGE_MODEL=gemma4:26b

# Optional: use Claude as judge instead of local model (higher quality)
# ANTHROPIC_API_KEY=sk-ant-...

# Ollama API key placeholder (not required but OpenAI client needs a value)
OPENAI_API_KEY=ollama

# Eval settings
MAX_ROUNDS=5
NUM_ATTACKS=50
